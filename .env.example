# =============================================================================
# NOC Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit your .env file. It is listed in .gitignore.
# =============================================================================

# Proxmox
PROXMOX_HOST=10.10.10.251
PROXMOX_TOKEN_ID=root@pam!hermes
PROXMOX_TOKEN_SECRET=<your-token-secret>

# Proxmox Backup Server
PBS_URL=https://10.10.10.77:8007
PBS_USERNAME=root@pam
PBS_PASSWORD=<your-pbs-password>

# Portainer (Docker)
PORTAINER_URL=http://10.10.10.237:9005
PORTAINER_USERNAME=admin
PORTAINER_PASSWORD=<your-portainer-password>

# Wazuh
WAZUH_API_URL=https://10.10.10.233:55000
WAZUH_API_USER=hermes
WAZUH_API_PASSWORD=<your-wazuh-password>
WAZUH_INDEXER_HOST=https://10.10.10.233:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=<your-indexer-password>

# CrowdSec
CROWDSEC_API_URL=http://10.10.10.237:18080
CROWDSEC_API_KEY=<your-crowdsec-api-key>
CROWDSEC_MACHINE_USER=<machine-user>
CROWDSEC_MACHINE_PASS=<machine-pass>

# UniFi
UNIFI_URL=https://10.10.10.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=<your-unifi-password>

# AdGuard Home
ADGUARD_PASSWORD=<your-adguard-password>
# Second AdGuard instance (optional)
ADGUARD2_URL=
ADGUARD2_USERNAME=
ADGUARD2_PASSWORD=

# Uptime Kuma
UPTIME_KUMA_URL=http://10.10.10.237:3661
UPTIME_KUMA_API_KEY=<your-uptime-kuma-api-key>

# URBackup
URBACKUP_URL=http://10.10.10.76:55414
URBACKUP_USERNAME=admin
URBACKUP_PASSWORD=<your-urbackup-password>

# Cloudflare
CLOUDFLARE_TOKEN=<your-cloudflare-api-token>
CLOUDFLARE_ZONE_ID=<your-zone-id>

# Nginx Proxy Manager
NPM_URL=http://10.10.10.237:81
NPM_EMAIL=admin@example.com
NPM_PASSWORD=<your-npm-password>

# Tailscale
TAILSCALE_API_KEY=<your-tailscale-api-key>

# Plex
PLEX_URL=http://10.10.10.101:32400
PLEX_TOKEN=<your-plex-token>

# Tautulli
TAUTULLI_URL=http://10.10.10.101:8181
TAUTULLI_API_KEY=<your-tautulli-api-key>

# Sonarr
SONARR_URL=http://10.10.10.101:8989
SONARR_API_KEY=<your-sonarr-api-key>

# Radarr
RADARR_URL=http://10.10.10.101:7878
RADARR_API_KEY=<your-radarr-api-key>

# Prowlarr
PROWLARR_URL=http://10.10.10.101:9696
PROWLARR_API_KEY=<your-prowlarr-api-key>

# SABnzbd
SABNZBD_URL=http://10.10.10.101:8080
SABNZBD_API_KEY=<your-sabnzbd-api-key>

# Overseerr
OVERSEERR_URL=http://10.10.10.101:5055
